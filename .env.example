# Flutter Architect AI Environment Configuration
# 
# PRIORITY ORDER (first match wins):
# 1. GitHub Actions Secrets (in 'development' environment)
# 2. System Environment Variables (Docker, CI/CD, etc.)
# 3. .env file (local development)
# 4. Defaults
#
# For Local Development:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. DO NOT commit .env to version control
#
# For GitHub Actions:
# 1. Go to Settings > Environments > development
# 2. Add these secrets:
#    - GROQ_API_KEY
#    - APP_VERSION
#    - LOG_LEVEL
#
# REQUIRED VARIABLES
# ==================

# Groq AI API Key (REQUIRED for AI features)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL VARIABLES
# ==================

# Application version
APP_VERSION=1.0.0

# Logging verbosity: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Debug mode (false for production)
DEBUG=false

# OPTIONAL ADVANCED CONFIGURATION
# ================================

# Custom output directory for generated projects
# CUSTOM_OUTPUT_DIR=/path/to/output

# AI Model to use (default: mixtral-8x7b-32768)
# AI_MODEL=mixtral-8x7b-32768

# API request timeout in seconds
# API_TIMEOUT=30
